{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AstroBox CreatorConsole",
  "version": "0.1.0",
  "identifier": "moe.astralsight.astroboxcc",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "AstroBox CreatorConsole",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["astroboxcc"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "files": {
        "Resources/Assets.car": "resources/Assets.car"
      }
    },
    "iOS": {
      "minimumSystemVersion": "15.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
